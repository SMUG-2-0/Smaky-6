	.TITLE	LPDRIV	.PROC	Z80	.REF	FLO	;A. CAPT	17.01.83;L I N E   P R I N T E R   D R I V E R   R E V   2 - 1;*****************************************************	;CONDITIONAL ASSEMBLING	NOMINU	=	0	;lower-case into capital	STAND	=	0	;Standard driver	OKI80	=	0	;M80 microline from OKI	OKI82	=	0	;M82 microline from OKI	OKI84	=	1	;M84 microline from OKI	.IF	STAND+OKI80+OKI82+OKI84-1PLEASE SPECIFY ONE AND ONLY ONE PRINTER TYPE	.ENDIF	.IF	(OKI82!OKI84)&NOMINUSORRY THIS CONFIGURATION IS NOT ALLOWED	.ENDIF	.IF	STAND;STANDARD OVERLAY DRIVER	.ENDIF	.IF	OKI80;OVERLAY DRIVER FOR OKI MICROLINE 80 LINE PRINTER	.ENDIF	.IF	OKI82;OVERLAY DRIVER FOR OKI MICROLINE 82 LINE PRINTER	.ENDIF	.IF	OKI84;OVERLAY DRIVER FOR OKI MICROLINE 84 LINE PRINTER	.ENDIF;=============================================================	.SBTTL	RULES FOR LINE PRINTER DRIVER;- the driver must be located at adress PROGR;- the name of the line printer driver file must be LP.SY;- the driver lengh must not exceed 1400 octal;- the driver must start at PROGR, but without starting;  adress. In other words, the driver must be assembled;  without starting adress. That mean:;	.END  or  .END START  with START = 1;- the return with carry set abort the job and show the error;  number in A. Return carry clear is the normal return.;- the use of memory positions as save register in the driver;  can be dangerous, because the driver is destroyed after;  every directory read or .W ?ERROR. Adresses PROGR+4375 to;  PROGR+4377 can be used as safe register position.;HOW WORK SAMOS LINE PRINTER OVERLAY;For every works, SAMOS test if the driver overlay file LP.SY;is present in directory buffer (PROGR). If no, SAMOS try;to load it before to jump at PROGR adress. If the load of;LP.SY was unsucessful the job is aborted with an error;message. If the file LP.SY already exist in buffer, SAMOS;jump, of course, direct in it.;SAMOS jump into driver in this way:;OPEN WORK;*********;IN:	Carry clear and A = 0;	B = channel number;the driver MUST give back:;OUT:	A = channel number;CLOSE WORK;**********;IN:	Carry clear and A <> 0;CURRENT JOB;***********;IN:	Carry set;	DE = character pointer;=============================================================	.SBTTL	PROGRAM	;PARAMETERS	PROGR	= 21400		;program location	CNTCAR	= PROGR+4376	;safe char counter	CNTLIN	= PROGR+4377	;safe line counter	DEFLIN	= 72.		;default number of lines	OVERFL	= 6		;line overflow offset	CONT	= 31		;floppy control peripheric	BSLASH	= 134		;back slash character	.LOC	PROGRLP:	PUSH	AF		;save entry status	XOR	A,A		;be sure that no floppies	LOAD	$CONT,A		;run during the printing	INC	A		;be sure that we have	.W	?ENI50		;interruption	LOAD	HL,#2		;compute entry	ADD	HL,SP		;stack adress	LOAD	SVSTK,HL	;and save it	POP	AF		;restore entry status	JUMP.,CS LP1		;do current job	OR	A,A	JUMP,NE	CLOSE		;do end jobOPEN:	XOR	A,A	LOAD	CNTCAR,A	;reset char counter	.IF	STAND	LOAD	A,#CR		;reset print head	CALL	WMOD	LOAD	A,B		;return channel number	RET	.ENDIF	.IF	OKI80!OKI82!OKI84	LOAD	D,B		;save channel number in D	.IF	OKI82!OKI84	LOAD	BC,#17.*400+24.	;set printer ready in case not	CALL	W2PAR		;and clear buffer	.IF	OKI82;##############################################################;L'UTILISATION SPECIALE DU GENERATEUR DE CARACTERE INTERDIT LE;PASSAGE EN LONGUE LIGNE SI L'ON EST EN CARACTERE REDUIT ET QUE;LA SELECTION SOFTWARE DE LA LONGUEUR DU FORMULAIRE EST ACTIVE;IL FAUT DONC DESACTIVER LA SELECTION AVANT D'INITIALISER;L'IMPRIMANTE ET INITIALISER LA LONGUEUR DU FORMULAIRE EN;DERNIER.	LOAD	E,#0	CALL	INIFF;##############################################################	.ENDIF	.ENDIF	CALL	INLIN		;read user number of lines	LOAD	CNTLIN,A	;and init lines counter	.IF	OKI82!OKI84	LOAD	E,A	.ENDIF		LOAD	A,#CR		;reset print head and	CALL	WPAR		;init char counter	.IF	OKI82!OKI84	CALL	INIMODINIFF:	LOAD	C,#'F		;select init of form lengh	CALL	WESCC	LOAD	L,E	LOAD	H,#0		;convert binary form lengh	.W	?BINBCD		;into BCD first,	LOAD	A,L		;and after into ASCII	AND	A,#17	ADD	A,#'0	LOAD	C,A		;in C register	LOAD	A,L	RRC	A	RRC	A	RRC	A	RRC	A	AND	A,#17	ADD	A,#'0	LOAD	B,A		;and b	CALL	W2PAR		;init printer form lengh	LOAD	C,#'5		;set top of form a the	CALL	WESCC		;actual line	LOAD	A,D		;restore saved channel in D	RET	.ENDIFINIMOD:	LOAD	HL,#LPSTAT	;HL= printer status adress	.IF	OKI82!OKI84	LOAD	A,#30.		;select the character	TEST	(HL):0		;mode according with	JUMP.,EQ INIMO1		;the status register	DEC	A	.IF	OKI84	DEC	A	.ENDIFINIMO1:	CALL	WPAR	LOAD	A,#31.	TEST	(HL):1	JUMP.,EQ INIMO5	CALL	WPARINIMO5:	.ELSE	LOAD	A,#31.		;select the character	TEST	(HL):1		;mode according with	JUMP.,NE INIMO1		;the status register	DEC	A	TEST	(HL):0	JUMP.,EQ INIMO1	DEC	AINIMO1:	CALL	WPAR		;init the character mode	.ENDIF	.IF	~OKI84	LOAD	C,#'A		;select the margin mode	TEST	(HL):2		;according with the	JUMP.,NE INIMO2		;status register	INC	CINIMO2:	CALL	WESCC		;init the margin mode	.ENDIF	LOAD	C,#'6		;select lines spacing	TEST	(HL):3		;according with the	JUMP.,EQ INIMO3		;status register	LOAD	C,#'8INIMO3:	CALL	WESCC		;init the lines spacing	.IF	OKI80	LOAD	A,D		;restore saved channel in D	.ENDIF	RET			;and return it	.ENDIFLP1:	.IF	OKI84	CALL	OVERF?		;do pagination if necessary	.ELSE	LOAD	HL,#LPSTAT	;test if necessary to manage	TEST	(HL):4		;overflow pagination	JUMP.,NE LP3	LOAD	A,CNTLIN	;if yes, test if necessary	SUB	A,#OVERFL+1	;to execute a form feed	CALL,LO	DOFFLP3:	.ENDIF	LOAD	A,(DE)		;read the character	.IF	OKI80!OKI82!OKI84	TEST	(HL):7		;test if previous char was	JUMP.,EQ LP4		;a back slash or macro char	CLR	(HL):7		;if yes clear flag bit	COMP	A,#BSLASH	;test if double back slash	JUMP.,EQ WRCAR		;if yes, print back slash	COMP	A,#'*		;if * control char, return	JUMP.,EQ INIMOD		;to initial status	COMP	A,#'D		;test if screen dump	JUMP,EQ	DMPSCR		;if yes, jump to routine	COMP	A,#'I		;test if inverted screen dump	JUMP,EQ	DMPSC1		;if yes, jump to routine	.IF	OKI84	COMP	A,#'Q		;test if quality char mode	JUMP.,NE LP31		;if not skeep	SET	(HL):5		;else set quality bitLP31:	COMP	A,#'N		;test if cancel quality mode	JUMP.,NE LP32		;if not skeep	CLR	(HL):5		;else clear quality bitLP32:	.ENDIF	LOAD	HL,#CMDTB	;else look in tableLP6:				;if the character	COMP	A,(HL)		;is a valid printer control	INC	HL		;character	JUMP.,NE LP5	LOAD	B,(HL)		;if yes, init BC with the	INC	HL		;corresponding control code	LOAD	C,(HL)		;in table and	JUMP	W2PAR		;init the printerLP5:	INC	HL		;else continue the research	INC	HL	TEST	(HL):7	JUMP,EQ	LP6	COMP	A,#SPACE	;if not found print if lower	JUMP.,HS LP51		;than space corresp char	.IF	OKI84	OR	A,#200	.ELSE	OR	A,#240	.ENDIF	JUMP.	LP4LP51:	AND	A,#37		;and if upper	.IF	OKI84	OR	A,#240		;corresp greek char	.ELSE	OR	A,#300		;corresp greek char	.ENDIFLP4:	COMP	A,#BSLASH	;test if back slash char	JUMP.,EQ LP8	COMP	A,#MACRO	;test if macro char	JUMP.,NE LP7LP8:				;if yes active flag in	SET	(HL):7		;printer status register	RETLP7:	.ENDIF	COMP	A,#CR		;test if carriage return	JUMP.,EQ DOCR		;if yes execute	COMP	A,#TAB		;test if tab	JUMP.,EQ DOTAB		;if yes execute	COMP	A,#FF		;test if form feed	JUMP.,EQ DOFF		;if yes executeWRCAR:	.IF	NOMINU	COMP	A,#'a		;test if small	JUMP.,LO LP2		;if yes transform it	COMP	A,#'z+1		;into capital	JUMP.,HS LP2	CLR	A:5	.ENDIF	.IF	OKI84	COMP	A,#SPACE	;test if special char	JUMP.,HS 10$		;if not skeep	OR	A,#200		;else set special char bit10$:	LOAD	HL,#LPSTAT	;pointer printer status	TEST	(HL):5		;test if quality char	JUMP.,EQ LP2		;if not skeep	OR	A,A		;else test if special char	JUMP,SC	30$		;if not skeep	COMP	A,#'!200	;test if lower cases	JUMP.,LO 60$		;if not skeep	COMP	A,#'+201	JUMP.,HS 60$	LOAD	HL,#TSPCAR-('!200)	ADD	A,L		;else point conv table	LOAD	L,A		;and compute pointer	JUMP.,CC 20$		;in table	INC	H20$:	LOAD	A,(HL)		;take conversion char	JUMP.	LP2		;and print30$:	LOAD	HL,#TSPCAR-1	;point conversion table40$:	INC	HL		;increment table pointer	TEST	(HL):7		;test if end of table	JUMP.,NE LP2		;if yes skeep	COMP	A,(HL)		;test if same char	JUMP.,NE 40$		;if not try next60$:	PUSH	AF		;else save char	LOAD	C,#'T		;set emphasized printing	CALL	WESCC	LOAD	C,#'0		;with non-quality char	CALL	WESCC	POP	AF		;and write the char	CALL	LP2	INC	C		;restore quality char	CALL	WESCC	LOAD	C,#'I		;with non-emphsized printing	JUMP	WESCC	.ENDIF	.IF	OKI80!OKI82	COMP	A,#SPACE	JUMP.,HS LP2	OR	A,#240		;transform special characters	.ENDIFLP2:	.IF	STAND	CALL	WMOD		;write character	.ENDIF	.IF	OKI80!OKI82!OKI84	CALL	WPAR		;write character	.ENDIFINCNT:	LOAD	A,CNTCAR	INC	A		;increment tab caract. counter	LOAD	CNTCAR,A	AND	A,#7	RETDOCR:	XOR	A,A	LOAD	CNTCAR,A	;clear character counter	LOAD	A,CNTLIN	DEC	A	JUMP.,NE DOCR1	CALL	INLINDOCR1:	LOAD	CNTLIN,A	.IF	~OKI84	LOAD	A,#LF		;send line feed	.ENDIF	.IF	STAND	CALL	WMOD	.ENDIF	.IF	OKI80!OKI82	CALL	WPAR	.ENDIF	.IF	OKI84	CALL	WLF		;send line feed	.ENDIF	.IF	STAND	LOAD	A,#CR		;and carriage return	CALL	WMOD	.ENDIF	RETDOTAB:	LOAD	A,#SPACE	;send space character	.IF	STAND	CALL	WMOD	.ENDIF	.IF	OKI80!OKI82!OKI84	CALL	WPAR	.ENDIF	CALL	INCNT	JUMP,NE	DOTAB	RETCLOSE:	.W	?GETFON		;wait until no more	JUMP,NE	CLOSE		;function keyDOFF:	LOAD	A,LPSTAT	TEST	A:4	JUMP.,NE DOCR	CALL	INLIN		;init A with user nb of lines	LOAD	B,A	LOAD	A,CNTLIN	COMP	A,B		;test if already new page	.IF	OKI82!OKI84	.IF	OKI82	RET,EQ			;if yes return	LOAD	A,B	LOAD	CNTLIN,A	;init line counter	XOR	A,A		;and clear	LOAD	CNTCAR,A	;char counter	LOAD	A,#FF		;execute form feed	JUMP	WPAR	.ENDIF	.IF	OKI84	LOAD	A,B		;init line counter	LOAD	CNTLIN,A	JUMP.,EQ DOFF0		;skeep if already new page	PUSH	AF		;save line/page value	XOR	A,A		;clear char counter	LOAD	CNTCAR,A	LOAD	A,#FF		;and execute form feed	CALL	WPAR	POP	AF		;restore line/page valueDOFF0:	PUSH	DE	PUSH	HL	LOAD	E,A		;init form feed again	CALL	INIFF		;in case previous	POP	HL		;screen dump	POP	DE	RET	.ENDIF	.ELSE	RET,EQ	LOAD	B,ADOFF1:	CALL	DOCR		;send carriage return	DECJ,NE	B,DOFF1		;until new page	RET	.ENDIFINLIN:	LOAD	A,SNBLIN	;take number of lines selected	OR	A,A		;test if no zero	RET,NE	LOAD	A,#DEFLIN	;if yes take default value	RET	.IF	STANDWMOD:	PUSH	AF		;save character	.W	?GETFON		;test if function key	JUMP.,EQ WMOD1	COMP	A,#KILL		;if yes, test if kill function	JUMP.,EQ WMOD2		;if yes, abortWMOD1:	POP	AF		;restore character	.W	?IFWMOD		;try to send it	JUMP,CS	WMOD		;if not ready wait	RET			;if sended, returnWMOD2:	LOAD	HL,SVSTK	;restore original entry	LOAD	SP,HL		;stack adress	LOAD	A,#EREOF	;set end of file error	SETC			;and return carry set	RET	.ENDIF	.IF	OKI80!OKI82DMPSCR:	XOR	A,A		;init dump flag in normal modeDMPSC1:				;entry which init dump flag	LOAD	DMPFLG,A	;for inverted mode	LOAD	HL,#SALPHA-NCAR	;init HL with alpha screen adr	LOAD	IX,#SGRA-NCAR	;init IX with graph screen adr	LOAD	C,#'A		;select printing mode for	CALL	WESCC		;a graphic dump.	LOAD	A,#35		;no margin, reduced char	CALL	WPAR	LOAD	A,LAMODI	;look the screen status	AND	A,#14		;test if graphic mode	JUMP.,NE DMPSC7	INC	C		;if no, correct printing mode	CALL	WESCC		;margin, standard char	LOAD	B,#LINES	;and init B with	LOAD	A,#36		;number of lines	CALL	WPARDMPSC2:	LOAD	DE,#NCAR	;pointer onto next	ADD	HL,DE		;line	PUSH	HL		;save the pointer	ADD	HL,DE		;pointer to end of new line	LOAD	C,E		;init C with number of char/lnDMPSC3:				;as char counter	DEC	HL		;point previous char	LOAD	A,(HL)		;read the char	COMP	A,#SPACE	;test if space char	JUMP.,NE DMPSC4		;if not, skeep	DEC	C		;else correct char counter	JUMP,NE	DMPSC3		;and test next previous charDMPSC4:	POP	HL		;restore beg line pointer	PUSH	HL		;and save again	JUMP.,EQ DMPSC6		;skeep if zero valid charDMPSC5:	LOAD	A,(HL)		;read a char from alpha screen	CLR	A:7		;clear invertion bit	INC	HL	CALL	WRCAR		;print the char	DEC	C		;dec char counter	JUMP,NE	DMPSC5		;continue until end of lineDMPSC6:	CALL	DOCR		;print a carriage return	POP	HL	DECJ,NE	B,DMPSC2	;continue until end of screen	JUMP	INIMOD		;exit with restoring userDMPSC7:				;printing status	LOAD	B,#LINES	;init B with number of linesDMPSC8:	LOAD	DE,#NCAR	;point onto next	ADD	HL,DE		;alpha line	ADD	IX,DE		;and graphic line origin	PUSH	HL		;save alpha pointer	PUSH	IX		;and graphic pointer	ADD	HL,DE		;point end of alpha line	ADD	IX,DE		;point end of graphic line orig	LOAD	C,E		;init C with number of char/lnDMPSC9:				;as char counter	LOAD	A,LAMODI	;test if alpha+graphic screen	TEST	A:3		;status mode	JUMP.,NE DMPS10		;if not skeep	DEC	HL		;else point previous alpha char	LOAD	A,(HL)		;read alpha char	COMP	A,#SPACE	;test if space char	JUMP.,NE DMPS11		;if not skeepDMPS10:	DEC	IX		;point previous graphic char	LOAD	A,(IX)		;read first graphic char	CALL	TSTGRA		;test if null char	JUMP.,NE DMPS11		;if not skeep	LOAD	A,(IX)+NCAR	;read second graphic char	CALL	TSTGRA		;test if null char	JUMP.,NE DMPS11		;if not skeep	PUSH	IX		;save graphic pointer	ADD	IX,DE		;compute a next line pointer	LOAD	A,(IX)+NCAR	;and read last graphic char	POP	IX		;restore graphic pointer	CALL	TSTGRA		;test if null char	JUMP.,NE DMPS11		;if not skeep	DEC	C		;else correct char counter	JUMP,NE	DMPSC9		;and test next previous charDMPS11:	LOAD	A,C		;char counter in A	LOAD	SNCAR,A		;save char counter	POP	IX		;restore graphic pointer	POP	HL		;restore alpha pointer	PUSH	HL		;save alpha pointer again	PUSH	IX		;save graphic pointer again	JUMP.,EQ DMPS15		;skeep if zero valid charDMPS12:	LOAD	A,LAMODI	;test if alpha+graphic screen	TEST	A:3		;status mode	JUMP.,NE DMPS13	LOAD	D,(HL)		;if yes, take a char from	CLR	D:7		;alpha screen, clear invertion	INC	HL		;bit	LOAD	A,#SPACE	;test if this char is a space	COMP	A,D	JUMP.,EQ DMPS13		;if yes, print graphic	CALL	WRCAR		;if no, print alpha	LOAD	A,D		;(that mean a priority for	CALL	WRCAR		;alpha screen onto graphic)	JUMP.	DMPS14DMPS13:	LOAD	E,(IX)		;read a byte on graphic screen	LOAD	D,(IX)+NCAR	;and a byte on next line	PUSH	BC		;in order to have all info	CALL	WRGRA		;needed to print two graphic	POP	BC		;charDMPS14:	INC	IX	DEC	C	JUMP,NE	DMPS12		;continue until end of lineDMPS15:	CALL	DOCR		;print a carriage return	POP	IX		;restore beg graphic line pt	LOAD	DE,#NCAR	;compute pointer onto	ADD	IX,DE		;next graphic line	PUSH	IX		;save graphic pointer	LOAD	A,SNCAR		;again C = number of char/line	LOAD	C,A	OR	A,A		;test if zero valid char in ln	JUMP.,EQ DMPS18		;if yes skeepDMPS16:	LOAD	E,(IX)		;read again the second byte	LOAD	A,(IX)+NCAR	;of the previous operation and	PUSH	BC		;a new one on the next line	LOAD	B,#4		;execute bits transfertDMPS17:				;between this two bytes, in	RL	A		;order to be compatible	RLC	E		;with WRGRA routine.	DECJ,NE	B,DMPS17	LOAD	D,A	CALL	WRGRA		;print the two new graphic	POP	BC		;char	INC	IX	DEC	C	JUMP,NE	DMPS16		;continue until end of lineDMPS18:	CALL	DOCR		;print a carriage return	POP	IX	LOAD	DE,#NCAR	;skeep graphic screen pointer	ADD	IX,DE		;onto next line	POP	HL	DEC	B	JUMP,NE	DMPSC8	JUMP	INIMOD		;until screen end				;and exit with restoring				;user printing status.TSTGRA:	PUSH	BC		;save BC	LOAD	B,A		;save graphic char in B	LOAD	A,DMPFLG	;read dump flag	OR	A,A		;test if inverted mode	LOAD	A,B		;restore char in A	POP	BC		;restore BC	JUMP.,EQ TSTGR1		;skeep if not inverted mode	CPL	A		;else invert graphic byteTSTGR1:	OR	A,A		;test graphic byte	RET			;and returnWRGRA:	LOAD	A,DMPFLG	;test the screen dump mode	OR	A,A		;flag	JUMP.,EQ WRGR0	LOAD	A,E		;if set to inverted mode,	CPL	A		;invert the two graphic	LOAD	E,A		;bytes in D and E.	LOAD	A,D		;before to execute	CPL	A		;the routine	LOAD	D,AWRGR0:	LOAD	BC,#200*400+200	TEST	E:0		;this routine prepare two	JUMP.,EQ WRGR1		;graphic char in B and C	SET	C:3		;according to the two graphicWRGR1:				;bytes in D and E	TEST	E:1	JUMP.,EQ WRGR2	SET	C:2WRGR2:	TEST	E:2	JUMP.,EQ WRGR3	SET	B:3WRGR3:	TEST	E:3	JUMP.,EQ WRGR4	SET	B:2WRGR4:	TEST	E:4	JUMP.,EQ WRGR5	SET	C:1WRGR5:	TEST	E:5	JUMP.,EQ WRGR6	SET	C:0WRGR6:	TEST	E:6	JUMP.,EQ WRGR7	SET	B:1WRGR7:	TEST	E:7	JUMP.,EQ WRGR8	SET	B:0WRGR8:	TEST	D:4	JUMP.,EQ WRGR9	SET	C:5	SET	C:6WRGR9:	TEST	D:5	JUMP.,EQ WRG10	SET	C:4WRG10:	TEST	D:6	JUMP.,EQ WRG11	SET	B:5	SET	B:6WRG11:	TEST	D:7	JUMP.,EQ W2PAR	SET	B:4	JUMP.	W2PAR	.ENDIF	.IF	OKI84DMPSC1:	SETC			;carry set for inverted modeDMPSCR:	LOAD	A,LAMODI	;read screen status	CLR	A:0		;update bit 0	JUMP.,CC DMPSC2		;according with	SET	A:0		;with kind of dumpDMPSC2:	LOAD	DMPFLG,A	;save dump status	LOAD	B,#11.		;select graphic vert	CALL	IPITCH		;vert pitch	CALL	WLF		;feed one line	LOAD	HL,#43000	;point graphic screen	LOAD	DE,#40000-100	;and alpha screen	LOAD	B,#20.		;init line counterDMPSC3:	PUSH	BC		;save line counter	EX	HL,DE		;point next alpha line	LOAD	BC,#100	ADD	HL,BC	EX	HL,DE	LOAD	C,#3		;3 graphic lines for 1 SM6 lineDMPSC4:	PUSH	DE		;save alpha pointer	LOAD	B,#64.		;init counter for 64. charDMPSC5:	PUSH	BC		;save char counter	LOAD	A,DMPFLG	;read dump status	LOAD	B,A		;save in B	TEST	B:2		;test if graphic	JUMP.,EQ DMPSC6		;if not skeep	LOAD	A,(DE)		;read alpha char	COMP	A,#SPACE	;test if space	LOAD	A,#176		;A = no alpha char window mask	JUMP.,EQ DMPSC8		;if space skeep	TEST	B:3		;test if only graphic screen	JUMP.,NE DMPSC8		;if yes, skeep	LOAD	A,#2		;select alpha window mask	COMP	A,C		;according with actual	LOAD	A,#160		;graphic line number	JUMP.,LO DMPSC8	LOAD	A,#36	JUMP.,NE DMPSC8DMPSC6:	LOAD	A,#2		;test if graphic line	COMP	A,C		;with alpha char	LOAD	A,#SPACE	;A=space in case	JUMP.,NE DMPSC7		;if not skeep	LOAD	A,(DE)		;read char	CLR	A:7		;clear inverted char bitDMPSC7:	INC	DE		;increment alpha pointer	INC	HL		;increment graphic pointer	PUSH	HL		;write alpha char	CALL	WRCAR	POP	HL	JUMP.	DMPS15		;and skeepDMPSC8:	INC	DE		;increment alpha pointer	PUSH	DE		;save alpha pointer	LOAD	D,A		;save alpha window mask in D	LOAD	E,B		;save dump status in E	LOAD	C,#'%		;write header of	CALL	WESCC		;graphic command	LOAD	A,#'1	CALL	WPAR	LOAD	BC,#12.		;we write 12 OKI graphic char	CALL	W2PAR		;for 4 SM6 graphic char	LOAD	B,#4		;init loop for 4 SM6 char	LOAD	C,(HL)		;read graphic char	INC	HL		;inc graphic pointerDMPSC9:	XOR	A,A		;clear all bits	TEST	C:3		;test second line SM6 bit	JUMP.,EQ DMPS10		;if clear skeep	OR	A,#17		;select according OKI bitsDMPS10:	TEST	C:7		;test first line SM6 bit	JUMP.,EQ DMPS11		;if clear skeep	OR	A,#360		;select according OKI bitsDMPS11:	TEST	E:0		;test if inverted mode	JUMP.,EQ DMPS12		;if not skeep	CPL	A		;invert OKI graphic byteDMPS12:	AND	A,D		;mask bits	TEST	E:1		;test if small point mode	JUMP.,EQ DMPS13		;if not skeep	AND	A,#355		;mask bits for small point modeDMPS13:	CALL	WPAR		;write graphic char	TEST	E:1		;test if small point mode	JUMP.,EQ DMPS14		;if not skeep	XOR	A,A		;clear byte if small point modeDMPS14:	CALL	WPAR		;write two more	CALL	WPAR		;OKI graphic char	SLC	C		;shift SM6 graphic byte	DECJ,NE	B,DMPSC9	;and loop until end	POP	DE		;restore alpha pointerDMPS15:	POP	BC		;restore char counter	DECJ,NE	B,DMPSC5	;loop until end of line	CALL	WLF		;feed one line	POP	DE		;restore beg of alpha line pt	DEC	C		;loop until 3 OKI graphic	JUMP,NE	DMPSC4		;line for one SM6 line	POP	BC		;restore SM6 screen line cnt	DEC	B		;loop until all screen done	JUMP,NE	DMPSC3	LOAD	HL,#LPSTAT	;point printer status	LOAD	BC,#16.*400+29.	;select B=correction in vert	TEST	(HL):3		;pitch and C=corresp number	JUMP.,EQ DMPS16		;of lines according with	LOAD	BC,#3.*400+38.	;lines/inch user selectionDMPS16:	PUSH	BC		;save number of line	CALL	IPITCH		;make vert skeep correction	CALL	INIMOD		;init printer again	LOAD	A,CNTLIN	;read line counter	POP	BC		;restore corresp nb of lines	SUB	A,C		;sub to counter	JUMP.,CC DMPS17		;skeep if no overflow	LOAD	B,A		;save sub result in B	CALL	INLIN		;A=number of line/page	ADD	A,B		;add to resultDMPS17:	LOAD	CNTLIN,A	;set line counter to this value	LOAD	E,A		;and also FF value	CALL	INIFF	XOR	A,A		;clear line char counter	LOAD	CNTCAR,AOVERF?:	LOAD	HL,#LPSTAT	;test if necessary to manage	TEST	(HL):4		;overflow pagination	RET,NE	LOAD	A,CNTLIN	;if yes, test if necessary	SUB	A,#OVERFL+1	;to execute a form feed	CALL,LO	DOFF	RETIPITCH:	LOAD	C,#29.		;standard char	PUSH	BC		;save vert pitch and char mode	LOAD	C,#'%		;write vert pitch	CALL	WESCC		;header command	LOAD	A,#'9	CALL	WPAR	POP	BC		;restore pitch and char mode	CALL	W2PAR		;and writeWLF:	LOAD	A,#LF		;write line feed char	JUMP.	WPAR	.ENDIF	.IF	OKI80!OKI82!OKI84WESCC:	LOAD	B,#ESC		;write ESC and char in CW2PAR:	LOAD	A,B		;send to printer the	CALL	WPAR		;two characters	LOAD	A,C		;in B and C registersWPAR:	PUSH	AF		;save character	.W	?GETFON		;test if function key	JUMP.,EQ WPAR1	COMP	A,#KILL		;if yes, test if kill function	JUMP.,EQ WPAR2		;if yes, abortWPAR1:	POP	AF		;restore character	.IF	OKI82!OKI84;##############################################################;CORRECTION SOFTWARE DE L'ANOMALIE DES OKI 82 ET 84 QUI NE SONT;PAS READY SI ELLES SONT DESELECTIONNEES PAR SOFTWARE	COMP	A,#17.	JUMP.,NE WPAR3	LOAD	$PAR,A	RETWPAR3:;##############################################################	.ENDIF	.W	?IFWPAR		;try to send it	JUMP,CS	WPAR		;if not ready wait	RET			;if sended, returnWPAR2:	LOAD	HL,SVSTK	;restore original entry	LOAD	SP,HL		;stack adress	LOAD	A,#EREOF	;set end of file error	SETC			;and return carry set	RET	.IF	OKI84TSPCAR:	.B	'# '$ '/ '< '> '@ '[ '\ '] '^ '_ '{ '| '} '~	.B	200	.ENDIFCMDTB:	.IF	OKI82!OKI84	.B	'T,0,20.	;start of vert tab init seq	.B	'C,0,11.	;vertical tab channel sel	.B	'W,17.,0	;printer ready to work	.B	'H,0,19.	;printer hold (local condition)	.B	'J,ESC,11.	;direct line skeep	.B	'F,ESC,'F	;form lengh selection	.B	'O,ESC,'5	;set origin of first line	.B	'K,0,24.	;clear buffer	.ENDIF	.IF	OKI84	.B	'+,ESC,'J	;set superscript char	.B	'#,ESC,'K	;cancel superscript char	.B	'-,ESC,'L	;set underscript char	.B	'=,ESC,'M	;cancel underscript char	.B	'_,ESC,'C	;set underline mode	.B	'~,ESC,'D	;cancel underline mode	.B	'G,ESC,'H	;set emphasized printing mode 1	.B	'U,ESC,'T	;set emphasized printing mode 2	.B	'A,ESC,'I	;cancel emphasized printing	.B	'Q,ESC,'1	;set quality printing	.B	'N,ESC,'0	;cancel quality printing	.B	'R,0,28.	;reduced character	.B	'M,0,29.	;medium character	.ELSE	.B	'R,0,29.	;reduced character	.ENDIF	.B	'S,0,30.	;standard character	.B	'E,0,31.	;elarged character	.B	'6,ESC,'6	;6 lines/inch	.B	'8,ESC,'8	;8 lines/inch	.IF	~OKI84	.B	'M,ESC,'B	;margin (64 standard char)	.B	'L,ESC,'A	;continuous (80 standard char)	.ENDIF	.B	200DMPFLG:	.BLKB	1		;screen dump flag memory	.ENDIF	.IF	OKI80!OKI82SNCAR:	.BLKB	1		;temporary char counter save	.ENDIFSVSTK:	.BLKW	1		;original stack value save	.END