BASIC REV 2-8  MODE D'EMPLOI RESUME***********************************LES PARAMETRES ENTRE { } SONT OPTIONNELS*** TOUCHES A ACTIONS SPECIALES ***CTRL C		arrte l'excution d'un programme.ESC		arrte l'excution d'un programme ou		dbranchement en fonction de ON ESC.CTRL B		efface le display alpha et graphique.CTRL S		supprime l'affichage en cours de programme.CTRL Q		autorise l'affichage en cours de programme.CTRL A		stop/start de l'execution du programme.BACK SPACE	efface le caractre derrire le pointeur.DELETE		efface le caractre sous le pointeur.RETURN		termine la ligne.NMI		aucun effet.*** TOUCHE FONCTION (EDITION) ***TEXT		dplacementKILL+TEXT	dtruit				F 1 car  droite				G 1 mot  droite				C jusque tout  droite				D 1 car  gauche				S 1 mot  gauche				R jusque tout  gauche*** COMMANDES DIRECTES ***RUN		clear les DIM et les variables puis dmarre le		programme  la premire ligne existante.XEQ		idem  RUN sans clear des DIM et des variables.HELP		affiche sur l'cran le texte que vous lisez.LIBRARY		liste sur l'cran tous les fichiers .BS.DIRECTORY	liste sur l'cran tous les fichiers.NEW		efface le programme et les variables.NEW *		efface seulement le programme.		rpondre par Y si oui.CON		continue apres CTRL C ,ESC ou STOP.AUTO start,step	initialise la numrotation automatique des		lignes pour l'dition.AUTO		start,step par dfaut depuis 100 par step 10.REN start,step	renumrote les lignes.REN		start,step par dfaut depuis 100 par step 10.EDIT # 		passe en mode dition de ligne depuis		la ligne #.EDIT		idem depuis la premire ligne.ENTER fichier	lit un fichier ASCII.BS sur le disque.COPY fichier	crit un fichier ASCII.BS  sur le disque.DUMP fichier	crit un DUMP.SM sur le disque.BYE		retour au CLI.LIST (#),(#)	liste sur l'cran le programme BASIC.		LIST		tout		LIST 100	la ligne 100		LIST 100,	depuis 100		LIST ,100	jusqu' 100		LIST 100,200	entre 100 et 200GOTO #		excute  partir de la ligne # sans dtruire		les variables.GOSUB #		excute une sous-routine  la ligne #.*** COMMANDES PROGRAMMES OU DIRECTES ***REM		remarques.!		identique a REM.DATA expr,expr ...		mmorisation de donnes.READ variable,variable$ ...	lecture de ces donnes.RESTORE				pointeur des donnes au dbut.IF test condition THEN instruction.FOR variable = expression TO expression STEP expression.NEXT variableGOTO #GOSUB #RETURNOPEN FILE(#n,#m),"nom"{,reclen,maxrec}ouvre un fichier sur le canal #n et en mode #m	mode = 0	cration en accs alatoire.	mode = 1	criture en accs squentiel.	mode = 2	modification en accs alatoire.	mode = 3	lecture en accs squentiel.	reclen:	paramtre optionnel indiquant la			longueur de chaque enregistrement.	maxrec:	paramtre optionnel indiquant le			nombre d'enregistrements.SPOS(#n,#m)	positionne le fichier #n sur l'enregistrement		#m  (accs alatoire uniquement).ATTENTION:	un fichier cr en mode squentiel ne		peut pas tre relu en mode alatoire.INPUT{"texte"}variable,variable$,...INPUT FILE(#),variable,...	   lit du canal #.INPUT{"texte"} LINE,variable$,...  lit une chaine ASCII.LET variable = expressionSTOPENDPRINT expressions ou "texte"PRINT FILE(#),expressions ou "texte"	(print dans le canal #)?		idem  PRINTPSCR		dump des crans sur l'imprimante.CLOSE		ferme tous les fichiers ouverts.CLOSE FILE(#)	ferme le canal #.DELETE "nom", ...  destruction de fichiers.NAME "oldname,newname" renomme un fichier.COMPRESS "rp:" compression du rpertoire rp:LOAD "nom"	charge un programme depuis un programme.LOAD PICTURE "nom" charge dans l'cran graphique le fichier		image graphique "nom"SAVE PICTURE "nom" sauve l'cran graphique sur disque en		crant un fichier image graphique "nom"TAB (n)		tabulation de n positions depuis le dbut		de la ligne.@ (l,c)		positionne le pointeur  la ligne l et  la		colonne c dans un print.# (e,d)		slectionne le format d'affichage des nombres		de e chiffres suivi de d dcimales.RANDOMIZE	coup de sac du gnrateur de nombres alatoiresON variable GOTO #,#,# ...ON ESC THEN #ON ERR THEN #DIM A(x,y)	rserve un tableau de x sur y.DIM A(x)	rserve un vecteur de longeur x.DIM A$(x,y)	rserve un tableau de string de		x lments de longueur y.CHANGE	A TO B$	convertit un tableau en string.	B$ TO C	convertit un string en tableau.DEFFN A(X)=X+1	dfinition d'une fonction.Y=FN A(Z)	calcul de Y selon la fonction A avec X valant Z:		sparateur de commandes.STEP ON		affiche en inverse vido sur l'cran la		ligne excute. Attend une touche quelconque		pour excuter la ligne suivante.STEP		idemSTEP OFF	arrte le mode step.TRACE ON	affiche en inverse vido sur l'cran la		ligne excute.TRACE		idemTRACE OFF	arrte le mode trace.ALPHA ON	active l'cran alpha-numrique.ALPHA		idemALPHA OFF	dsactive l'cran alpha-numrique.GRAPH ON	active l'cran graphique.GRAPH		idemGRAPH OFF	dsactive l'cran graphique.MOVE (x,y,m)	trace un trait depuis le dernier point		jusqu'en (x,y). Le trait est fait selon le		mode m.		m=0	efface		m=1	-------		m=2	=======		m=3	.......		m=4	- - - -		m=5	-.-.-.-		m=6	+ + + +		m=7	sautMOVE (x,y)	idem selon le dernier mode utilis.SCREEN		efface le display graphique.PAGE		efface le display alpha-numrique.BEEP		donne un coup de buzzer rapide.*** STRING ***"ABCDEF"'ABCDEF'	chaine de caractres.A$=CHR$(X)	cre un string d'un car. gal  X.A$=NUM$(X)	cre un string reprsentant le nombre X.A$=NUM$(#(e,d)X) cre un string reprsentant le nombre X		 avec le format fixe #(e,d).A$=SPACE$(X)	cre un string de X espaces.A$=STRING$(X,Y)	cre un string de long. X et contenant des		 caractres gaux  Y.X=INSTR(Y,A$,B$) comparaison de strings.X=LEN(A$)	longueur d'un string.X=ASCII(A$)	valeur du premier caractre d'un string.X=VAL(A$)	valeur d'un string reprsentant un nombre.B$=LEFT$(A$,X)		BBBBBBBBBB.......			<-------->			     XB$=RIGHT$(A$,X)		......BBBBBBBBBBB			      <--------->				   XB$=MID$(A$,X,Y)		......BBBBBBB....			<-----X----->			   X	 Y*** FONCTIONS MATHEMATIQUES ***ABS(expr.)	valeur absolueSQR(expr.)	racine carreINT(expr.)	partie entireTRUNC(expr.)	partie entire tronqueARND(expr.)	partie entire arrondieSGN(expr.)	signeRND(expr.)	valeur alatoire comprise entre 0 et expr.SIN(expr.)	sinusCOS(expr.)	cosinusTAN(expr.)	tangenteATN(expr.)	arc-tangenteLN(expr.)	logarithme nprien (base e)LOG(expr.)	logarithme naturel (base 10)EXP(expr.)	anti-log nprien+		addition-		soustraction*		multiplication/		division^		lvation  une puissancePI		constante 3.14159*** FONCTIONS LOGIQUES ***NOT		nonOR		ouAND		et<=		plus petit ou gal>=		plus grand ou gal<>		diffrent<		plus petit>		plus grand=		gal*** FONCTIONS SPECIALES ***KEY		donne la valeur dcimale de la touche presse		donne zro si aucune touche n'a t pressePOS		position courante du pointeur dans la ligneFRE		donne le nombre de bytes restantsERO		donne le numro de la dernire erreurEOF(#)		end of file sur le canal #YEAR		donne l'anneMONTH		donne le moisDAY		donne le jourHOUR		donne les heuresMIN		donne les minutesSEC		donne les secondes;		sparateur sans tabulation,		sparateur avec sparation*** COMMANDES SPECIALES ET DANGEREUSES ***OUT $,#		sort la valeur # dans le priphrique $.A=INP($)	lit le priphrique $.POKE adresse,#	LOAD adresse dcimale,#.A=PEEK(adresse)	LOAD A,adresse dcimale.CALL adresse	CALL sous-routine assembleur		 l'adresse dcimale.EPSITEC-SYSTEM  S.A.				31.12.82   AC