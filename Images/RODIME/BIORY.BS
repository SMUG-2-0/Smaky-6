100 REM PROGRAMME DE CALCUL DU BIORYTHME110 SCREEN 120 GRAPH ON 130 DIM J$(12)140 FOR I=1 TO 12150 READ J$(I)160 NEXT I170 DATA JANVIER,FEVRIER,MARS,AVRIL,MAI,JUIN,JUILLET,AOUT,SEPREMBRE,OCTOBRE,NOVEMBRE,DECEMBRE180 ON ESC THEN 2330190 PAGE 200 PRINT "C A L C U L   D U   B I O R Y T H M E"210 PRINT "*************************************"220 PRINT 230 PRINT "ENTREZ VOTRE DATE DE NAISSANCE"240 INPUT "JOUR: ",C250 IF C>31 THEN 240260 INPUT "MOIS: ",B270 IF B>12 THEN 260280 INPUT "ANNEE ",A290 IF A>=100 THEN 320300 LET A=A+1900310 GOTO 330320 IF A<1583 THEN 280330 PRINT 340 PRINT "ENTREZ LA DATE DE CALCUL DU BIORYTHME"350 INPUT "JOUR: ",F360 IF F>31 THEN 350370 INPUT "MOIS: ",E380 IF E>12 THEN 370390 INPUT "ANNEE: ",D400 IF D>=100 THEN 430410 LET D=D+1900420 GOTO 490430 IF D<1583 THEN 390440 IF A>D THEN 500450 IF A<D THEN 520460 IF B>E THEN 500470 IF B<E THEN 520480 IF C>F THEN 500490 GOTO 520500 PRINT "VOUS N'ETIEZ PAS NE !!!"510 GOTO 330520 IF D-A<150 THEN 560530 PRINT "DESOLEZ MAIS VOUS SEREZ MORT A CETTE DATE !!!"540 PRINT "ALORS VOTRE BIORYTHME EST PLUTOT PLAT !!!"550 GOTO 330560 LET A1=A570 LET B1=B580 LET C1=C590 LET D1=D600 LET D1=D610 LET E1=E620 LET F1=F630 LET C=1640 LET F=1650 LET A=D660 LET B=E670 IF B<>12 THEN 700680 LET E=0690 LET D=D+1700 LET E=E+1710 GOSUB 2120720 IF F1>Z THEN 840730 LET A=A1740 LET B=B1750 LET D=A760 LET E=B770 IF B<>12 THEN 800780 LET E=0790 LET D=D+1800 LET E=E+1810 GOSUB 2120820 IF C1>Z THEN 840830 GOTO 870840 PRINT "UNE DES DATES EST IMPOSSIBLE !!!"850 PRINT 860 GOTO 230870 LET C=C1880 LET F=F1890 LET E=E1900 LET D=D1910 LET C=F920 LET A=D930 LET B=E940 IF E<>12 THEN 970950 LET E=0960 LET D=D+1970 LET E=E+1980 GOSUB 2120990 REM CALCUL VARIABLES DES JOURS SUR GRAPHIQUE HORIZ.1000 LET P4=C1010 LET P3=C1020 FOR P9=1 TO 51030 LET P4=P4+11040 IF P4>Z THEN 10801050 NEXT P91060 LET P5=P41070 GOTO 11101080 LET P4=11090 NEXT P91100 LET P5=P41110 FOR P9=1 TO 51120 LET P4=P4+11130 IF P4>Z THEN 11701140 NEXT P91150 LET P6=P41160 GOTO 12001170 LET P4=11180 NEXT P91190 LET P6=P41200 FOR P9=1 TO 51210 LET P4=P4+11220 IF P4>Z THEN 12601230 NEXT P91240 LET P7=P41250 GOTO 12901260 LET P4=11270 NEXT P91280 LET P7=P41290 LET A=A11300 LET B=B11310 LET C=C11320 LET D=D11330 LET E=E11340 LET F=F11350 GOSUB 21201360 SCREEN 1370 PAGE 1380 PRINT 1390 PRINT @(9,6);"I  ";"I  ";"I  ";"I  ";"I  ";"I  ";"I  ";1400 PRINT "I  ";"I  ";"I  ";"I  ";"I  ";"I  ";"I  ";"I  ";"I  ";1410 PRINT "I  ";"I  ";"I  "1420 PRINT @(9,64);P31430 PRINT @(10,17);P51440 PRINT @(10,32);P61450 PRINT @(10,47);P71460 MOVE (15,17,7)1470 MOVE (15,107,1)1480 MOVE (13,63,7)1490 MOVE (255,63,1)1500 PRINT @(2,1);"+1"1510 PRINT @(16,1);"-1"1520 MOVE (13,20,7)1530 MOVE (17,20,1)1540 MOVE (13,105,7)1550 MOVE (17,105,1)1560 PRINT @(18,5);"PHYSIQUE";1570 PRINT @(18,18);"EMOTIF";1580 PRINT @(18,29);"INTELLECT";1590 MOVE (20,3,7)1600 MOVE (50,3,6)1610 MOVE (73,3,7)1620 MOVE (95,3,3)1630 MOVE (119,3,7)1640 MOVE (149,3,1)1650 LET Z1=Z1660 LET K=151670 LET N2=231680 GOSUB 22301690 LET B4=A81700 MOVE (K,L,7)1710 FOR P9=1 TO 201720 LET K=K+121730 LET Z=Z+11740 GOSUB 22301750 MOVE (K,L,6)1760 NEXT P91770 LET Z=Z11780 LET K=151790 LET N2=281800 GOSUB 22301810 LET B5=A81820 MOVE (K,L,7)1830 FOR P9=1 TO 201840 LET K=K+121850 LET Z=Z+11860 GOSUB 22301870 MOVE (K,L,4)1880 NEXT P91890 LET Z=Z11900 LET K=151910 LET N2=331920 GOSUB 22301930 LET B6=A81940 MOVE (K,L,7)1950 FOR P9=1 TO 201960 LET K=K+121970 LET Z=Z+11980 GOSUB 22301990 MOVE (K,L,1)2000 NEXT P92010 LET Z6=B4+B5+B62020 LET Z6=Z6/32030 LET Z6=INT(Z6*100)2040 LET Z6=Z6/1002050 PRINT @(0,5);"NE LE: ";C;J$(B);" ";A,"POUR LE: ";F;J$(E);" ";D2060 PRINT @(1,5);"MOYENNE DU JOUR: ";Z62070 PRINT @(18,42);"ENCORE (OUI,NON) ";2080 INPUT M$2090 IF LEFT$(M$,1)="O" THEN 22702100 GOTO 23302110 REM CALCUL DU NOMBRE DE JOURS ENTRE DEUX DATES2120 IF B<3 THEN 21502130 LET X=365*A+C+31*(B-1)-INT(0.4*B+2.3)+INT(A/4)-INT(3/4*INT(A/100+1))2140 GOTO 21602150 LET X=365*A+C+31*(B-1)+INT((A-1)/4)-INT(3/4*INT((A-1)/100+1))2160 IF E<3 THEN 21902170 LET Y=365*D+F+31*(E-1)-INT(0.4*E+2.3)+INT(D/4)-INT(3/4*INT(D/100+1))2180 GOTO 22002190 LET Y=365*D+F+31*(E-1)+INT((D-1)/4)-INT(3/4*INT((D-1)/100+1))2200 LET Z=Y-X2210 RETURN 2220 REM CALCUL DE LA VALEUR DU BIORYTHME2230 LET A8=SIN((Z/N2-INT(Z/N2))*2*3.14159)2240 LET L=A8*432250 LET L=L+632260 RETURN 2270 SCREEN 2280 PAGE 2290 PRINT "VOULEZ-VOUS CHANGER DE DATE DE NAISSANCE (OUI,NON) "2300 INPUT M$2310 IF LEFT$(M$,1)="O" THEN GOTO 2302320 GOTO 3402330 SCREEN 2340 PAGE 2350 END 