	.TITLE FPRINT PROGRAM	.PROC	Z80	.REF	FLO;FOREGROUND PRINT PROGRAM;	A. CAPT		17.01.83	REV	=	'2	VAR	=	'2;This program is able to print in foreground. That mean you;can work during the printing.;CONDITONNAL ASSEMBLING	;Driver function	NOMINU	=	0	;lower-case into capital	;Driver type	STAND	=	0	;Standard driver	OKI80	=	0	;M80 microline from OKI	OKI82	=	0	;M82 microline from OKI	OKI84	=	1	;M84 microline form OKI	;Output channel	PARAL	=	1	;On parallel port	SERIAL	=	0	;On serial port USART $4	MODEM	=	0	;On serial port USART $6	.IF	OKI80+OKI82+OKI84-1**** SORRY, YOU CAN'T HAVE TWO PRINTER !!!	.ENDIF	.IF	~(OKI80!OKI82!OKI84)**** YOU MUST SELECT A DRIVER TYPE	.ENDIF	.IF	PARAL+SERIAL+MODEM-(PARAL!SERIAL!MODEM)**** PLEASE SELECT ONLY ONE OUTPUT CHANNEL	.ENDIF	.IF	~(PARAL!SERIAL!MODEM)**** YOU MUST SELECT AN OUTPUT CHANNEL	.ENDIF	.IF	OKI80;DRIVER FOR OKI80 LINE PRINTER	.ENDIF	.IF	OKI82;DRIVER FOR OKI82 LINE PRINTER	.ENDIF	.IF	OKI84;DRIVER FOR OKI84 LINE PRINTER	.ENDIF;- FF for standard A4 paper (72 lines in pitch of 6 lines/inch);PARAMETERS	.IF	MODEM!SERIAL	;Parameters for USART	.IF	MODEM	USA	=	6	;peripheric adress	.ENDIF	.IF	SERIAL	USA	=	4	;peripheric adress	.ENDIF	SUSA	=	USA+1	;status peripheric adress	REMODE	=	100	MODE	=	316	COMMAND	=	5	M51	=	40	M11	=	2	.ENDIF	DEFLIN	= 72.		;default number of lines	OVERFL	= 6		;line overflow offset	ERINT	= 110		;special error message number	BSLASH	= 134	.IF	PARAL	SALVE	=	8.	;max char treated during int	.ELSE	SALVE	=	2	;max char treated during int	.ENDIF	RST70	=	42546	;restart 70 init memory adress	MARK	=	240	;foreground "lamp"	ADMARK	=	40077	;adress of foreground "lamp"	.IF	OKI80	OKI	=	'0	.ENDIF	.IF	OKI82	OKI	=	'2	.ENDIF	.IF	OKI84	OKI	=	'4	.ENDIF	.LOC	26000EXTFLG:	.BYTE	0;L I N E   P R I N T E R   D R I V E R   R E V   2 - 1;*****************************************************;IMPORTANT REMARK;If you modify this part, you must take care that the driver;must NEVER PUT INTERRUPT ON. That mean never use SYSTEM or;SAMOS CALL and instruction ION.DRIVER:	JUMP.,CS LP1		;do current job	OR	A,A	JUMP,NE	CLOSE		;do end jobOPEN:	XOR	A,A	LOAD	CNTCAR,A	;reset char counter	.IF	STAND	LOAD	A,#CR		;reset print head	CALL	WMOD	LOAD	A,B		;return channel number	RET	.ENDIF	.IF	OKI80!OKI82!OKI84	LOAD	D,B		;save channel number in D	.IF	OKI82!OKI84	LOAD	BC,#17.*400+24.	;set printer ready in case not	CALL	W2PAR		;and clear buffer	.IF	OKI82;##############################################################;L'UTILISATION SPECIALE DU GENERATEUR DE CARACTERE INTERDIT LE;PASSAGE EN LONGUE LIGNE SI L'ON EST EN CARACTERE REDUIT ET QUE;LA SELECTION SOFTWARE DE LA LONGUEUR DU FORMULAIRE EST ACTIVE;IL FAUT DONC DESACTIVER LA SELECTION AVANT D'INITIALISER;L'IMPRIMANTE ET INITIALISER LA LONGUEUR DU FORMULAIRE EN;DERNIER.	LOAD	E,#0	CALL	INIFF;##############################################################	.ENDIF	.ENDIF	CALL	INLIN		;read user number of lines	LOAD	CNTLIN,A	;and init lines counter	.IF	OKI82!OKI84	LOAD	E,A	.ENDIF		LOAD	A,#CR		;reset print head and	CALL	WRTCAR		;init char counter	.IF	OKI82!OKI84	CALL	INIMODINIFF:	LOAD	C,#'F		;select init of form lengh	CALL	WESCC	LOAD	L,E	LOAD	H,#0		;convert binary form lengh	CALL	BINBCD		;into BCD first,	LOAD	A,L		;and after into ASCII	AND	A,#17	ADD	A,#'0	LOAD	C,A		;in C register	LOAD	A,L	RRC	A	RRC	A	RRC	A	RRC	A	AND	A,#17	ADD	A,#'0	LOAD	B,A		;and b	CALL	W2PAR		;init printer form lengh	LOAD	C,#'5		;set top of form a the	CALL	WESCC		;actual line	LOAD	A,D		;restore saved channel in D	RET	.ENDIFINIMOD:	LOAD	HL,#LPSTAT	;HL= printer status adress	.IF	OKI82!OKI84	LOAD	A,#30.		;select the character	TEST	(HL):0		;mode according with	JUMP.,EQ INIMO1		;the status register	DEC	A	.IF	OKI84	DEC	A	.ENDIFINIMO1:	CALL	WRTCAR	LOAD	A,#31.	TEST	(HL):1	JUMP.,EQ INIMO5	CALL	WRTCARINIMO5:	.ELSE	LOAD	A,#31.		;select the character	TEST	(HL):1		;mode according with	JUMP.,NE INIMO1		;the status register	DEC	A	TEST	(HL):0	JUMP.,EQ INIMO1	DEC	AINIMO1:	CALL	WRTCAR		;init the character mode	.ENDIF	.IF	~OKI84	LOAD	C,#'A		;select the margin mode	TEST	(HL):2		;according with the	JUMP.,NE INIMO2		;status register	INC	CINIMO2:	CALL	WESCC		;init the margin mode	.ENDIF	LOAD	C,#'6		;select lines spacing	TEST	(HL):3		;according with the	JUMP.,EQ INIMO3		;status register	LOAD	C,#'8INIMO3:	CALL	WESCC		;init the lines spacing	.IF	OKI80	LOAD	A,D		;restore saved channel in D	.ENDIF	RET			;and return it	.ENDIFLP1:	LOAD	HL,#LPSTAT	;test if necessary to manage	TEST	(HL):4		;overflow pagination	JUMP.,NE LP3	LOAD	A,CNTLIN	;if yes, test if necessary	SUB	A,#OVERFL+1	;to execute a form feed	CALL,LO	DOFFLP3:	LOAD	A,(DE)		;read the character	.IF	OKI80!OKI82!OKI84	TEST	(HL):7		;test if previous char was	JUMP.,EQ LP4		;a back slash or macro char	CLR	(HL):7		;if yes clear flag bit	COMP	A,#BSLASH	;test if double back slash	JUMP.,EQ WRCAR		;if yes, print back slash	COMP	A,#'*		;if * control char, return	JUMP.,EQ INIMOD		;to initial status	.IF	OKI84	COMP	A,#'Q		;test if quality char mode	JUMP.,NE LP31		;if not skeep	SET	(HL):5		;else set quality bitLP31:	COMP	A,#'N		;test if cancel quality mode	JUMP.,NE LP32		;if not skeep	CLR	(HL):5		;else clear quality bitLP32:	.ENDIF	LOAD	HL,#CMDTB	;else look in tableLP6:				;if the character	COMP	A,(HL)		;is a valid printer control	INC	HL		;character	JUMP.,NE LP5	LOAD	B,(HL)		;if yes, init BC with the	INC	HL		;corresponding control code	LOAD	C,(HL)		;in table and	JUMP	W2PAR		;init the printerLP5:	INC	HL		;else continue the research	INC	HL	TEST	(HL):7	JUMP,EQ	LP6	COMP	A,#SPACE	;if not found print if lower	JUMP.,HS LP51		;than space corresp char	.IF	OKI84	OR	A,#200	.ELSE	OR	A,#240	.ENDIF	JUMP.	LP4LP51:	AND	A,#37		;and if upper	.IF	OKI84	OR	A,#240		;corresp greek char	.ELSE	OR	A,#300		;corresp greek char	.ENDIFLP4:	COMP	A,#BSLASH	;test if back slash char	JUMP.,EQ LP8	COMP	A,#MACRO	;test if macro char	JUMP.,NE LP7LP8:				;if yes active flag in	SET	(HL):7		;printer status register	RETLP7:	.ENDIF	COMP	A,#CR		;test if carriage return	JUMP.,EQ DOCR		;if yes execute	COMP	A,#TAB		;test if tab	JUMP.,EQ DOTAB		;if yes execute	COMP	A,#FF		;test if form feed	JUMP.,EQ DOFF		;if yes executeWRCAR:	.IF	NOMINU	COMP	A,#'a		;test if small	JUMP.,LO LP2		;if yes transform it	COMP	A,#'z+1		;into capital	JUMP.,HS LP2	CLR	A:5	.ENDIF	.IF	OKI84	COMP	A,#SPACE	;test if special char	JUMP.,HS 10$		;if not skeep	OR	A,#200		;else set special char bit10$:	LOAD	HL,#LPSTAT	;pointer printer status	TEST	(HL):5		;test if quality char	JUMP.,EQ LP2		;if not skeep	OR	A,A		;else test if special char	JUMP,SC	30$		;if not skeep	COMP	A,#'!200	;test if lower cases	JUMP.,LO 60$		;if not skeep	COMP	A,#'+201	JUMP.,HS 60$	LOAD	HL,#TSPCAR-('!200)	ADD	A,L		;else point conv table	LOAD	L,A		;and compute pointer	JUMP.,CC 20$		;in table	INC	H20$:	LOAD	A,(HL)		;take conversion char	JUMP.	LP2		;and print30$:	LOAD	HL,#TSPCAR-1	;point conversion table40$:	INC	HL		;increment table pointer	TEST	(HL):7		;test if end of table	JUMP.,NE LP2		;if yes skeep	COMP	A,(HL)		;test if same char	JUMP.,NE 40$		;if not try next60$:	PUSH	AF		;else save char	LOAD	C,#'T		;set emphasized printing	CALL	WESCC	LOAD	C,#'0		;with non-quality char	CALL	WESCC	POP	AF		;and write the char	CALL	LP2	INC	C		;restore quality char	CALL	WESCC	LOAD	C,#'I		;with non-emphsized printing	JUMP	WESCC	.ENDIF	.IF	OKI80!OKI82	COMP	A,#SPACE	JUMP.,HS LP2	OR	A,#240		;transform special characters	.ENDIFLP2:	.IF	STAND	CALL	WMOD		;write character	.ENDIF	.IF	OKI80!OKI82!OKI84	CALL	WRTCAR		;write character	.ENDIFINCNT:	LOAD	A,CNTCAR	INC	A		;increment tab caract. counter	LOAD	CNTCAR,A	AND	A,#7	RETDOCR:	XOR	A,A	LOAD	CNTCAR,A	;clear character counter	LOAD	A,CNTLIN	DEC	A	JUMP.,NE DOCR1	CALL	INLINDOCR1:	LOAD	CNTLIN,A	.IF	~OKI84	LOAD	A,#LF		;send line feed	.ENDIF	.IF	STAND	CALL	WMOD	.ENDIF	.IF	OKI80!OKI82	CALL	WRTCAR	.ENDIF	.IF	OKI84	CALL	WLF		;send line feed	.ENDIF	.IF	STAND	LOAD	A,#CR		;and carriage return	CALL	WMOD	.ENDIF	RETDOTAB:	LOAD	A,#SPACE	;send space character	.IF	STAND	CALL	WMOD	.ENDIF	.IF	OKI80!OKI82!OKI84	CALL	WRTCAR	.ENDIF	CALL	INCNT	JUMP,NE	DOTAB	RETCLOSE:DOFF:	LOAD	A,LPSTAT	TEST	A:4	JUMP.,NE DOCR	CALL	INLIN		;init A with user nb of lines	LOAD	B,A	LOAD	A,CNTLIN	COMP	A,B		;test if already new page	.IF	OKI82!OKI84	.IF	OKI82	RET,EQ			;if yes return	LOAD	A,B	LOAD	CNTLIN,A	;init line counter	XOR	A,A		;and clear	LOAD	CNTCAR,A	;char counter	LOAD	A,#FF		;execute form feed	JUMP	WRTCAR	.ENDIF	.IF	OKI84	LOAD	A,B		;init line counter	LOAD	CNTLIN,A	JUMP.,EQ DOFF0		;skeep if already new page	PUSH	AF		;save line/page value	XOR	A,A		;clear char counter	LOAD	CNTCAR,A	LOAD	A,#FF		;and execute form feed	CALL	WRTCAR	POP	AF		;restore line/page valueDOFF0:	PUSH	DE	PUSH	HL	LOAD	E,A		;init form feed again	CALL	INIFF		;in case previous	POP	HL		;screen dump	POP	DE	RET	.ENDIF	.ELSE	RET,EQ	LOAD	B,ADOFF1:	CALL	DOCR		;send carriage return	DECJ,NE	B,DOFF1		;until new page	RET	.ENDIFINLIN:	LOAD	A,SNBLIN	;take number of lines selected	OR	A,A		;test if no zero	RET,NE	LOAD	A,#DEFLIN	;if yes take default value	RETWLF:	LOAD	A,#LF		;write line feed char	JUMP	WRTCAR	.IF	OKI80!OKI82!OKI84WESCC:	LOAD	B,#ESC		;write ESC and char in CW2PAR:	LOAD	A,B		;send to printer the	CALL	WRTCAR		;two characters	LOAD	A,C		;in B and C registers	JUMP	WRTCAR	.ENDIF;F O R E G R O U N D   P R I N T   M A N A G E M E N T;*****************************************************;IMPORTANT REMARK;We recommand, not to modify this complex part of the program.;If you have a problem you cannot solve with DRIVERS part;modifications, please contact EPSITEC.START:	.W	?TEXTIM.ASCIZ	/FOREGROUND PRINT DRIVER OKI8<OKI> <REV>-<VAR><CR>/	LOAD	HL,#BNAORI	PUSH	HLSTART1:	LOAD	A,(DE)	LOAD	(HL),A	INC	HL	INC	DE	OR	A,A	JUMP,NE	START1	POP	DE	PUSH	DE	LOAD	HL,#BNAMAC	PUSH	HLSTART2:	LOAD	A,(DE)	LOAD	(HL),A	INC	HL	INC	DE	COMP	A,#'.	JUMP.,EQ START3	OR	A,A	JUMP,NE	START2	DEC	HL	LOAD	A,#'.	LOAD	(HL),A	INC	HLSTART3:	LOAD	A,#'M	LOAD	(HL),A	INC	HL	LOAD	A,#'C	LOAD	(HL),A	INC	HL	XOR	A,A	LOAD	(HL),A	POP	BC	POP	DE	.W	?RENAME	JUMP,CS	ER1	LOAD	D,B	LOAD	E,C	.W	?OPEBLK	JUMP,CS	ER2	LOAD	CHAN,A	.IF	MODEM!SERIAL	LOAD	BC,#NBPARA*400+SUSA	LOAD	HL,#TINIT	OUTIR	.ENDIF	IOF	LOAD	HL,RST70	LOAD	SRST70,HL	LOAD	HL,#PRINT	LOAD	RST70,HL	XOR	A,A	LOAD	CNTCAR,A	LOAD	RDDFLG,A	LOAD	FINFLG,A	LOAD	TIMOUT,A	LOAD	HL,#0	LOAD	BCOUNT,HL	CALL	INIBUF	CALL	DRIVER	.W	?RTN	ER1:	.W	?ERROR	.W	?RTNER2:	PUSH	AF	LOAD	DE,#BNAMAC	LOAD	BC,#BNAORI	.W	?RENAME	POP	HL	JUMP,CS	ER1	LOAD	A,H	JUMP	ER1PRINT:	PUSH	HL	LOAD	HL,SRST70	EX	(SP),HL	PUSH	HL	PUSH	DE	PUSH	BC	PUSH	AF	LOAD	HL,#ADMARK	LOAD	(HL),#MARK	LOAD	A,RDDFLG	OR	A,A	JUMP.,NE PRINT1	LOAD	B,#SALVEPRINT5:	PUSH	BC	LOAD	DE,INTPOI	LOAD	A,EXTFLG	OR	A,A	JUMP,SS	PRINT6	CALL	GETBYT	JUMP.,CS PRINT2	CALL	IFWRDA	JUMP.,CS PRINT0	LOAD	INTPOI,DE	XOR	A,A	LOAD	TIMOUT,A	LOAD	B,A	DECJ,NE	B,.	POP	BC	DECJ,NE B,PRINT5PRINT1:	POP	AF	POP	BC	POP	DE	POP	HL	RETPRINT0:	POP	BC	LOAD	A,EXTFLG	OR	A,A	JUMP,EQ	PRINT1	LOAD	A,TIMOUT	DEC	A	LOAD	TIMOUT,A	JUMP,NE	PRINT1	JUMP	PRINT4	PRINT6:	LOAD	HL,#USTOP	LOAD	NXINT,HL	POP	BC	JUMP.	PRINT7PRINT2:	POP	BC	LOAD	A,CHAN	OR	A,A	JUMP.,EQ PRINT3	LOAD	HL,#RDISK	LOAD	NXINT,HLPRINT7:	LOAD	A,#1	LOAD	RDDFLG,A	POP	AF	POP	BC	POP	DE	POP	HL	EX	(SP),HL	LOAD	HL,NXINT	EX	(SP),HL	PUSH	HL	LOAD	HL,SRST70	EX	(SP),HL	RETPRINT3:	LOAD	A,FINFLG	OR	A,A	JUMP.,NE PRINT4	INC	A	LOAD	FINFLG,A	CALL	INIBUF	CALL	DRIVER	JUMP	PRINT1PRINT4:	LOAD	HL,#ADMARK	LOAD	(HL),#SPACE	LOAD	HL,SRST70	LOAD	RST70,HL	JUMP	PRINT1GETBYT:	LOAD	A,(DE)	INC	DE	OR	A,A	RET,NE	LOAD	BC,BCOUNT	LOAD	A,B	OR	A,C	SETC	RET,EQ	LOAD	DE,POINT	CALL	INIBUF	PUSH	HL	PUSH	DE	PUSH	BC	SETC	CALL	DRIVER	POP	BC	POP	DE	INC	DE	DEC	BC	LOAD	POINT,DE	LOAD	BCOUNT,BC	POP	DE	JUMP	GETBYTWRTCAR:	PUSH	AF	PUSH	HL	LOAD	HL,WRPOI	LOAD	(HL),A	INC	HL	XOR	A,A	LOAD	(HL),A	LOAD	WRPOI,HL	POP	HL	POP	AF	RETINIBUF:	LOAD	HL,#INTBUF	LOAD	(HL),#0	LOAD	INTPOI,HL	LOAD	WRPOI,HL	RET;--------\; RDISK   >;--------/;Cette routine rempli le buffer de texte lorsque;celui-ci est vide. A la fin du fichier, il ferme;le ferme et le renomme a son nom original.USTOP:	PUSH	AF	PUSH	BC	PUSH	DE	PUSH	HL	LOAD	A,#177	LOAD	EXTFLG,A	LOAD	DE,#TEXBUF	LOAD	POINT,DE	LOAD	HL,#CHAN	LOAD	A,(HL)	OR	A,A	LOAD	A,#ERINT	JUMP.,EQ RDISK5	JUMP.	RDISK4RDISK:	PUSH	AF	PUSH	BC	PUSH	DE	PUSH	HL	LOAD	HL,#CHAN	LOAD	A,(HL)	LOAD	DE,#TEXBUF	LOAD	BC,#NBYTE	.W	?RDBLK	LOAD	POINT,DE	LOAD	BCOUNT,BC	JUMP.,CC RDISK3RDISK4:	PUSH	AF	LOAD	A,(HL)	LOAD	(HL),#0	.W	?CLOSE	LOAD	DE,#BNAMAC	LOAD	BC,#BNAORI	.W	?RENAME	POP	AF	COMP	A,#EREOF	JUMP.,EQ RDISK3RDISK5:	SET	A:7	LOAD	HL,#DEBMSG	LOAD	BC,#FINMSG-DEBMSG+1	CPIR	LOAD	BC,#0	JUMP,VC	RDISK2	LOAD	DE,#TEXBUFRDISK1:	LOAD	A,(HL)	OR	A,A	JUMP,SS	RDISK2	LOAD	(DE),A	INC	HL	INC	DE	INC	BC	JUMP	RDISK1RDISK2:	LOAD	BCOUNT,BCRDISK3:	XOR	A,A	LOAD	RDDFLG,A	POP	HL	POP	DE	POP	BC	POP	AF	RET;--------\; IFWRDA  >;--------/IFWRDA:	.IF	OKI82!OKI84;##############################################################;CORRECTION SOFTWARE DE L'ANOMALIE DE L'OKI82 QUI N'EST PAS;READY SI ELLE EST DESELECTIONNEE PAR SOFTWARE	COMP	A,#17.	JUMP.,NE IFWRD1	LOAD	$PAR,A	RETIFWRD1:;##############################################################	.ENDIF	.IF	PARAL	LOAD	C,#SPAR	.ELSE	LOAD	C,#SUSA	.ENDIF	LOAD	B,A	LOAD	A,$(C)	AND	A,#RDYP	LOAD	A,B	SETC	RET,EQ	DEC	C	LOAD	$(C),A	OR	A,A	RET	.IF	OKI82!OKI84DIV:	LOAD	A,#16.DIV2:	SETC	RLC	E	RLC	D	RLC	L	RLC	H	RET,CS	SUBC	HL,BC	JUMP.,HS DIV4	ADD	HL,BC	CLR	E:0	;Bit 0 si retablissementDIV4:	DEC	A	JUMP,NE	DIV2	OR	A,A	RETBINBCD:	PUSH	BC	PUSH	DE	EX	HL,DE	LOAD	HL,#SIMUL1	LOAD	B,#4BINB2:	PUSH	HL	PUSH	BC	LOAD	BC,#10.	;Diviseur	LOAD	HL,#0	;Poids forts	CALL	DIV	LOAD	A,L	POP	BC	POP	HL	RRD	A,(HL)	TEST	B:0	;?pair	JUMP.,EQ BINB4	INC	HLBINB4:	DECJ,NE	B,BINB2	LOAD	HL,SIMUL1	LOAD	A,E	POP	DE	POP	BC	RET	.ENDIF	; Table pour les commandes	; ------------------------	.IF	OKI84TSPCAR:	.B	'# '$ '/ '< '> '@ '[ '\ '] '^ '_ '{ '| '} '~	.B	200	.ENDIFCMDTB:	.IF	OKI82!OKI84	.B	'T,1,20.	;start of vert tab init seq	.B	'C,1,11.	;vertical tab channel sel	.B	'W,17.,1	;printer ready to work	.B	'H,1,19.	;printer hold (local condition)	.B	'J,ESC,11.	;direct line skeep	.B	'F,ESC,'F	;form lengh selection	.B	'O,ESC,'5	;set origin of first line	.B	'K,1,24.	;clear buffer	.ENDIF	.IF	OKI84	.B	'+,ESC,'J	;set superscript char	.B	'#,ESC,'K	;cancel superscript char	.B	'-,ESC,'L	;set underscript char	.B	'=,ESC,'M	;cancel underscript char	.B	'_,ESC,'C	;set underline mode	.B	'~,ESC,'D	;cancel underline mode	.B	'G,ESC,'H	;set emphasized printing mode 1	.B	'U,ESC,'T	;set emphasized printing mode 2	.B	'A,ESC,'I	;cancel emphasized printing	.B	'Q,ESC,'1	;set quality printing	.B	'N,ESC,'0	;cancel quality printing	.B	'R,1,28.	;reduced character	.B	'M,1,29.	;medium character	.ELSE	.B	'R,1,29.	;reduced character	.ENDIF	.B	'S,1,30.	;standard character	.B	'E,1,31.	;elarged character	.B	'6,ESC,'6	;6 lines/inch	.B	'8,ESC,'8	;8 lines/inch	.IF	~OKI84	.B	'M,ESC,'B	;margin (64 standard char)	.B	'L,ESC,'A	;continuous (80 standard char)	.ENDIF	.B	200DEBMSG:	.B	ERINT!200	.ASCII	/<CR><CR>***** user interruption *****<CR>/	.B	ERFNO!200	.ASCII	/<CR><CR>***** channel error *****<CR>/	.B	ERDTO!200	.ASCII	/<CR><CR>***** device timeout *****<CR>/	.B	ERDRO!200FINMSG:	.ASCII	/<CR><CR>***** read error *****<CR>/	.B	200	.IF	MODEM!SERIALTINIT:	.B	0,0,0,REMODE,MODE,COMMAND+M51+M11NBPARA	=	.-TINIT	.ENDIF	.IF	OKI82!OKI84SIMUL1:	.BLKW	1	.ENDIFINTPOI:	.BLKW	1WRPOI:	.BLKW	1POINT:	.BLKW	1BCOUNT:	.BLKW	1SRST70:	.BLKW	1NXINT:	.BLKW	1TIMOUT:	.BLKB	1RDDFLG:	.BLKB	1FINFLG:	.BLKB	1CNTCAR:	.BLKB	1CNTLIN:	.BLKB	1CHAN:	.BLKB	1BNAORI:	.BLKB	64.BNAMAC:	.BLKB	64.INTBUF:	.BLKB	128.	.LOC	(.+377)&177400NBYTE	=	40000-.TEXBUF:	.END	START