	.TITLE	ABHORLOGE.SR	.PROC	Z80	.REF	FLO	;AB 22 JUIN 1979 ;CONSTANTES DE DEFINITION DE FORME DE L'AFFICHAGE;================================================POSIN 	= 30.		;POSITION EN HAUTEURLSEG	= 20.		;LONGEUR D'UN SEGMENTESPA	= 15.		;ESPACEMENT DES DIGITSOBLI	= 5.		;PENTE DES DIGITS;DECLARATION DES CONSTANTES UTILISEES DANS LE PROGRAMME;======================================================NBSEG	= 13.		;NOMBRE DE SEGMENTS A TRACERTEMPS	= 372.		;TEMPS D'ATTENTEZERO	= 0UN	= 1DEUX	= 2TROIS	= 3QUATRE	= 4CINQ	= 5SIX	= 6SEPT	= 7HUIT	= 8.NEUF	= 9.DIX	= 10.LONGST	= SIX			;LONGEUR DE LA PILE DES TEMPSDEP1	= ESPA			;VALEUR DES DEPLACEMENTS DESDEP2	= DEP1+ESPA+LSEG	;DIGITSDEP3	= DEP2+DEUX*ESPA+LSEGDEP4	= DEP3+ESPA+LSEGDEP5	= DEP4+DEUX*ESPA+LSEGDEP6	= DEP5+ESPA+LSEGBL	= 0			;EFFACE LE SEGMENTTG	= 2			;TRAIT GRASTF	= 1			;TRAIT FINJU	= 7			;SAUTN1	= POSIN*YY		;NIVEAU DES POINTSN2	= N1+LSEG*YYN3	= N2+UN*YYN4	= N1+DEUX*LSEG*YYN5	= N4+UN*YYE1	= 0*XX			;ELOIGNEMENT DES POINTSE2	= E1+DEUX*XXE3	= E2+LSEG*XXE4	= E3+DEUX*XXOBLIC	= OBLI*XXOBLIC2	= DEUX*OBLI*XXP1	= E1+N2+OBLIC		;COORDONNEES DES POINTSP2	= E1+N1+OBLIC2P3	= E2+N1+OBLIC2P4	= E3+N1+OBLIC2P5	= E4+N1+OBLIC2P6	= E4+N2+OBLICP7	= E4+N3+OBLICP8	= E4+N4P9	= E4+N5P10	= E1+N5P11	= E1+N4P12	= E1+N3+OBLICP13	= E2+N2+OBLICP14	= E3+N2+OBLIC; DECLARATION DES TABLES UTILISEES; ================================; TABLE UTILISEE POUR L'INTRODUCTION DES DONNEESINTBL:	.BW	TROIS,TIMTBL+CINQ	.BW	DIX,TIMTBL+QUATRE	.BW	SIX,TIMTBL+TROIS	.BW	DIX,TIMTBL+DEUX	.BW	SIX,TIMTBL+UN	.BW	DIX,TIMTBL; TABLE DE CONTROLECTLTBL:	.B	DIX,TEMPS,SIX,TEMPS,DIX,TEMPS	.B	SIX,TEMPS,DIX,TEMPS,TROIS,TEMPS; TABLE DES TEMPSPTRTIM:	.BLKB	DEUX		;POINTEUR DE LA TIMTBLTIMTBL:	.BLKB	LONGST		;TABLE DES TEMPS; TABLE DES DEPLACEMENTS HORIZONTAUXPTRDEP:	.BLKB	DEUX		;POINTEUR DE LA DEPTBLDEPTBL:	.B	DEP1,DEP2,DEP3,DEP4,DEP5,DEP6; TABLE DE PARCOUR DE LA LIGNE POLYGONALE TRACANT LES DIGITSPTRPNT:	.BLKB	DEUX		;POINTEUR DE LA PNTTBLPNTTBL:	.W	P1,P2,P3,P4,P5,P6,P7,P8,P9,P10,P11,P12	.W	P13,P14; TABLE DE VALEUR GRAPHIQUE DES SEGMENTS DE LA LIGNE; POLYGONALEPTRCHF:	.BLKB	DEUX		;POINTEUR DE LA CHFTBLCHFTBL:	.B	TF,TF,TF,TF,TF,TF,TG,TF,TF,TF,TF,JU,BL	.B	BL,BL,BL,BL,TF,TF,TG,TG,BL,BL,BL,BL,BL	.B	BL,TF,TF,TF,TF,JU,BL,BL,TF,TF,TG,JU,TF	.B	BL,TF,TF,TF,TF,TG,TG,TF,TF,TF,BL,JU,TF	.B	TF,JU,BL,BL,TF,TG,TG,TG,BL,BL,BL,JU,TF	.B	TF,TF,TF,TF,BL,TG,TG,TF,TF,TF,BL,JU,TF	.B	TF,JU,BL,BL,BL,TG,TG,TF,TF,TF,TF,JU,TF	.B	BL,TF,TF,TF,TF,TG,TG,JU,BL,BL,BL,BL,BL	.B	TF,TF,TF,TF,TF,TG,TG,TF,TF,TF,TF,JU,TF	.B	TF,TF,TF,TF,TF,TG,TG,JU,BL,BL,BL,BL,TF; DECLARATION DES VARIABLES UTILISEES; ===================================CONT1:	.BLKB	UN		;COMPTEUR1CONT2:	.BLKB	UN		;COMPTEUR2DEPVAL:	.BLKB	DEUX		;VALEUR DU DEPLACEMENT; DECLARATION DES DIFFERENTS TEXTES A AFFICHER; ============================================TEXTE1:	.ASCIZ	"<CR>MISE A L'HEURE DE L'HORLOGE SMAKY "TEXTE2: .ASCIZ	"<CR>INTRODUISEZ L'HEURE SOUS LA FORME "TEXTE3: .ASCIZ	"<CR>HH.MM.SS<CR>"TEXTE4: .ASCIZ	"<CR>INTRODUCTION ILLEGALE, RECOMMENCEZ!<CR>"TEXTE5:	.ASCIZ	"<CR>TAPEZ UN CARACTERE POUR DEMARRER<CR>";#############################################################;#############################################################;#############################################################; DEBUT DU PROGRAMME;#############################################################;#############################################################;#############################################################;###################################################;#  SOUS-PROGRAMME DE MISE A L'HEURE DE L'HORLOGE  #;###################################################SETHRS:	.W	?TEXT,TEXTE1	;WRITELN(TEXTE1)	.W	?TEXT,TEXTE2	;WRITELN(TEXTE2)	.W	?TEXT,TEXTE3	;WRITELN(TEXTE3)	LOAD	B,#SIX		;CONTLEC := SIX	LOAD	HL,#INTBL	;HL := AD(INTBL); LECTURE DES DONNEES		;REPEATLOOP1:	.W	?GETCAR, ?DICAR	;READ(A),WRITE(A)	COMP	A,#'.	JUMP	EQ,LOOP1	;IF '.' THEN GOTO LOOP1	LOAD	C,#ZERO		;C := 0	LOAD	D,#'0		;D := '0'	PUSH	BC		;SAUVE CONTCAR	LOAD	B,(HL)		;B := (AD(INTBL))	INC	HL		;AD(INTBL) := AD(INTBL)+1; TESTE SI LES DONNEES SONT CORRECTESLOOP2:	COMP	A,D	JUMP	EQ,ENDL2	;IF A IN /'0..B/	INC	D		;THEN GOTO ENDL2	INC	C	DECJ,NE	B,LOOP2		;ELSE	POP	BC		;RAPPELLE CONTLEC	.W	?TEXT,TEXTE4	;WRITELN(TEXTE4)	JUMP	SETHRS		;GOTO SETHRS+1ENDL2:	LOAD	A,C		;A:=ORD(CARACLU)-ORD('0')	LOAD	E,(HL)		INC	HL	LOAD	D,(HL)	INC	HL	LOAD	(DE),A		;A MIS EN MEMOIRE	POP	BC		;RAPPELLE CONTLEC	DECJ,NE	B,LOOP1		;UNTIL CONTLEC = 0	RET;#######################################;#  SOUS-PROGRAMME DE CALCUL DU TEMPS  #;#######################################CTIME:	LOAD	HL,#TIMTBL	LOAD 	DE,#CTLTBL; INCREMENTATION D'UNE SECONDELOOP3:	LOAD	A,(DE)		LOAD	B,A		;B:=MAXIMUM	LOAD	A,(HL)		;A:=TEMPS	INC	A		;A:=A+1	COMP	A,B	JUMP	NE,ENDL3	;IF A#MAX THEN GOTO ENDL3	LOAD	A,#ZERO		;ELSE A:=0	LOAD	(HL),A	INC	HL	INC	DE	INC	DE	JUMP	LOOP3		;GOTO LOOP3ENDL3:	LOAD	(HL),A		;TEMPS:=A	LOAD	A,TIMTBL+CINQ	;IF TEMPS<24H THEN GOTO CTM3	COMP	A,#DEUX		;ELSE TEMPS:=0	JUMP	NE,CTM1	LOAD	A,TIMTBL+QUATRE	COMP	A,#QUATRE	JUMP	NE,CTM2	XOR	A,A	LOAD	TIMTBL+QUATRE,A	LOAD	TIMTBL+CINQ,A	JUMP	CTM3CTM1:	LOAD	BC,TIMTBL	;OPERATIONS BIDON POUR CREER	LOAD	B,#ZERO		;UN DELAIS DE COMPENSATIONCTM2:	LOAD	BC,TIMTBL	;IDEM	LOAD	BC,TIMTBLCTM3:	INC	DE	LOAD	A,(DE)	.W	?DELAY,TEMPS	;CREE UN RETARD	RET;##########################################;#  SOUS-PROGRAMME D'AFFICHAGE 7 SGMENTS  #;##########################################AFFICH:	LOAD	HL,#TIMTBL+CINQ	;ROUTINE AFFICHAGE 7 SEGMENTS	LOAD	PTRTIM,HL	LOAD	HL,#DEPTBL	LOAD	PTRDEP,HL	;INIT DES POINTEURS	LOAD	A,#SIX	LOAD	CONT1,A		;INIT COMPTEUR1LOOP4:	LOAD 	A,CONT1	LOAD	B,#ZERO	COMP	A,B		;WHILE CONT1#0 DO	JUMP	EQ,ENDL4	DEC	A	LOAD	CONT1,A	LOAD	HL,PTRDEP	LOAD	E,(HL)		;E:=((PTRDEP))	INC	HL	LOAD	PTRDEP,HL	;PTRDEP:=SUCC(PTRDEP)	LOAD	D,#ZERO		;DEPVAL:=E	LOAD	DEPVAL,DE	LOAD	HL,PTRTIM	LOAD	A,(HL)		;A:=((PTRTIM))	LOAD	C,(HL)		;C:=((PTRTIM))	DEC	HL	LOAD	PTRTIM,HL	;PTRTIM:=SUCC(PTRTIM)	ADD	A,A	ADD	A,A	ADD	A,A	ADD	A,A	SUB	A,C	SUB	A,C	SUB	A,C		;A:=A*13.	LOAD	HL,#CHFTBL	LOAD	DE,#ZERO	LOAD	E,A	ADD	HL,DE	LOAD	PTRCHF,HL	LOAD	HL,#PNTTBL+DEUX	LOAD	PTRPNT,HL	;INIT DES POINTEURS	LOAD	A,#NBSEG	LOAD	CONT2,A		;INIT COMPTEUR2	LOAD	HL,PNTTBL	;COORD PREMIER POINT	LOAD	DE,DEPVAL	ADD	HL,DE	EX	HL,DELOOP5:	LOAD	A,CONT2	LOAD	B,#ZERO	COMP	A,B	JUMP	EQ,LOOP4	;WHILE CONT2#0 DO	DEC	A	LOAD	CONT2,A	LOAD	HL,PTRCHF	LOAD	A,(HL)		;A:=((PTRCHF))	INC	HL	LOAD	PTRCHF,HL	;PTRCHF:=SUCC(PTRCHF)	CALL	CMOD		;MODE D'AFFICHAGE GRAPHIQUE	LOAD	HL,PTRPNT	LOAD	C,(HL)	INC	HL	LOAD	B,(HL)		;BC:=((PTRPNT))	INC	HL	LOAD	PTRPNT,HL	;PTRPNT:=SUCC(PTRPNT)	LOAD	HL,DEPVAL	;HL:=DEPVAL	ADD	HL,BC		;HL:=COORD POINT SUIVANT	CALL	SEGA		;AFFICHE LE SEGMENT	JUMP	LOOP5ENDL4:	RET;#########################;#  PROGRAMME PRINCIPAL  #;#########################DEBUT:	LOAD	C,#NLI	.W	?IDISORL2:	CALL	SETHRS	LOAD	A,TIMTBL+CINQ	;CONTROLE SI LE TEMPS 	COMP	A,#DEUX		;INTRODUIT NE DEPASSE PAS	JUMP	NE,START	;24 HEURES	LOAD	A,TIMTBL+QUATRE	COMP	A,#QUATRE	JUMP	LO,START	.W	?TEXT,TEXTE4	;TEMPS NON VALABLE	JUMP	ORL2START:	.W	?TEXT,TEXTE5	; ATTEND L'ORDRE DE DEPART	.W	?GETCAR	.W	?IGRA, ?CGRALOOP:	CALL	CTIME		;CETTE BOUCLE FAIT TOURNER	CALL	AFFICH		;L'HORLOGE	JUMP	LOOP	.END	DEBUT