{
  "name": "smaky6-simulator",
  "version": "0.6.0",
  "description": "Simulateur Smaky 6 — Epsitec SA",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist":       "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac":   "electron-builder --mac",
    "dist:all":   "electron-builder --win --linux"
  },
  "build": {
    "appId": "ch.epsitec.smaky6sim",
    "productName": "Smaky 6 Simulator",
    "files": [
      "index.html", "main.js", "preload.js",
      "rom18.js", "chargen_rom.js", "z80.js", "disasm.js", "smaky.js",
      "screenRenderer.js", "three.min.js", "OrbitControls.js", "three3d.js",
      "audio.js", "FLO?.JS", "HD?.JS"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always"
    },
    "linux": {
      "target": ["tar.gz"],
      "category": "Development",
      "icon": "icon.png"
    },
    "mac": {
      "target": ["zip"],
      "icon": "icon.png",
      "category": "public.app-category.developer-tools",
      "identity": null
    }
  },
  "devDependencies": {
    "electron":         "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
